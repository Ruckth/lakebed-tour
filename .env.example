# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
# Required in Vercel Production/Preview for `pnpm vercel-build`.
# Generate this in the Convex dashboard and add it as a Vercel environment variable.
CONVEX_DEPLOY_KEY=

# Clerk (optional for demo launch; keep placeholder to disable auth UI)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=placeholder

# Admin chat dashboard (Convex env; comma-separated Clerk account emails)
ADMIN_EMAILS=owner@example.com,manager@example.com

# Stripe (future production checkout only; live payment confirmation must use a trusted webhook)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (for transactional emails)
RESEND_API_KEY=re_...

# AI Chat (xAI Grok via OpenAI-compatible API)
AI_API_KEY=<xAI key>
AI_API_BASE_URL=https://api.x.ai/v1
AI_SIMPLE_MODEL=grok-4.3
AI_COMPLEX_MODEL=grok-4.3

# LINE Messaging API webhook
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
SITE_URL=http://localhost:3000

# Facebook Messenger Platform webhook
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v25.0

# Owner notification
OWNER_NOTIFICATION_EMAIL=owner@example.com
