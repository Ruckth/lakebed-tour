{
  "name": "360-tour",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "npx convex dev --once && next dev",
    "dev:convex": "npx convex dev",
    "dev:full": "npx convex dev & next dev",
    "build": "next build",
    "preview": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm typecheck",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "verify": "pnpm check && pnpm lint && pnpm test:unit && pnpm build",
    "vercel-build": "npx convex deploy --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL --cmd 'pnpm build'",
    "seed": "npx convex run seed:seedAll"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.176.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.7",
    "@internationalized/date": "^3.12.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.552.0",
    "next": "^16.0.0",
    "next-intl": "^4.12.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "three": "^0.175.0"
  }
}
